{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "epub-reader",
  "version": "0.1.0",
  "identifier": "com.github.mrkovalskik",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [{ "title": "EPUB Reader", "width": 480, "height": 860 }],
    "security": {
      "csp": {
        "default-src": "'self' 'unsafe-inline' 'unsafe-eval' asset: http://asset.localhost ipc: http://ipc.localhost blob: data:",
        "connect-src": "'self' asset: http://asset.localhost ipc: http://ipc.localhost blob: data:",
        "img-src": "'self' asset: http://asset.localhost blob: data:",
        "frame-src": "'self' asset: http://asset.localhost blob:",
        "script-src": "'self' 'unsafe-inline' 'unsafe-eval' asset: http://asset.localhost blob:"
      },
      "dangerousDisableAssetCspModification": ["script-src"],
      "assetProtocol": {
        "enable": true,
        "scope": {
          "allow": ["$APPDATA/**/*", "$TEMP/**/*"],
          "deny": []
        }
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/32x32.png","icons/128x128.png","icons/128x128@2x.png","icons/icon.icns","icons/icon.ico"]
  }
}
