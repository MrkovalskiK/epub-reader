{
  "$schema": "../gen/schemas/mobile-schema.json",
  "identifier": "mobile",
  "description": "Mobile app capabilities",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:default",
    "dialog:allow-open",
    "fs:default",
    "fs:allow-read-file",
    "fs:allow-write-file",
    "fs:allow-mkdir",
    "fs:allow-exists",
    {
      "identifier": "fs:scope",
      "allow": [
        { "path": "$APPDATA/**/*" },
        { "path": "$APPDATA" }
      ]
    },
    "store:default",
    "store:allow-get",
    "store:allow-set",
    "store:allow-save",
    "log:default",
    "log:allow-log",
    "native-bridge:allow-copy-uri-to-path"
  ]
}
