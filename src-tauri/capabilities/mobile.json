{
  "$schema": "../gen/schemas/mobile-schema.json",
  "identifier": "mobile",
  "description": "Mobile app capabilities",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:default",
    "dialog:allow-open",
    "fs:default",
    "fs:allow-read-file",
    "store:default",
    "store:allow-get",
    "store:allow-set",
    "store:allow-save",
    "log:default",
    "log:allow-log"
  ]
}
