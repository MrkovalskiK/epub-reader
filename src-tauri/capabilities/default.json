{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default app capabilities",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:default",
    "dialog:allow-open",
    "fs:default",
    "fs:allow-read-file",
    "store:default",
    "store:allow-get",
    "store:allow-set",
    "store:allow-save",
    "log:default",
    "log:allow-log",
    "native-bridge:allow-copy-uri-to-path"
  ]
}
